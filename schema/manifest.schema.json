{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sage-harness/schema/manifest.schema.json",
  "title": "SAGE manifest",
  "description": "docs/sage_harness/.manifest.json — spec/render/claims 해시와 conformance 추적 (staleness 판정원)",
  "type": "object",
  "required": ["sage_version", "host_runtime", "assets"],
  "properties": {
    "sage_version": { "type": "string" },
    "generator_version": { "type": "string" },
    "template_version": { "type": "string" },
    "host_runtime": { "enum": ["claude", "codex"] },
    "assets": {
      "type": "object",
      "description": "키 = '<kind>s/<id>' (예: agents/backend, hooks/pre-phase4-checklist-gate)",
      "additionalProperties": { "$ref": "#/$defs/assetEntry" }
    }
  },
  "$defs": {
    "sha": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "assetEntry": {
      "type": "object",
      "required": ["spec_hash", "render_hash", "conformance"],
      "properties": {
        "spec_hash": {
          "$ref": "#/$defs/sha",
          "description": "host-neutral spec md 해시"
        },
        "claims_hash": {
          "$ref": "#/$defs/sha",
          "description": "agent/skill 의 {id}.claims.yml 해시 (hook은 없음)"
        },
        "canonical_hash": {
          "$ref": "#/$defs/sha",
          "description": "hook 정본 알고리즘(scripts/sage_harness/hooks/{id}.sh) 해시 (hook 전용)"
        },
        "render_hash": {
          "type": "object",
          "description": "target 런타임별 산출물 해시. cross_model on이면 claude+codex 둘 다",
          "properties": {
            "claude": { "$ref": "#/$defs/sha" },
            "codex": { "$ref": "#/$defs/sha" }
          },
          "additionalProperties": false,
          "minProperties": 1
        },
        "conformance": { "enum": ["PASS", "FAIL", "STALE", "UNKNOWN"] },
        "risk": { "type": "array", "items": { "type": "string" } },
        "unresolved": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    }
  }
}
