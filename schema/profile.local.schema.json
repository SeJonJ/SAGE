{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SAGE machine-local capability profile",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "installed_hosts": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "enum": ["claude", "codex"] }
        }
      }
    },
    "capabilities": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "claude": { "type": "boolean" },
        "codex": { "type": "boolean" }
      }
    },
    "cross_model": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" }
      }
    },
    "knowledge_capture": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "vault_path": { "type": "string", "minLength": 1, "pattern": "^[^\\u0000]+$" }
      }
    },
    "models": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "available": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "claude": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,199}$" }
            },
            "codex": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:/-]{0,199}$" }
            }
          }
        }
      }
    }
  }
}
